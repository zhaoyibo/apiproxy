PORT=8080

# Required: admin password for the web UI login
ADMIN_KEY=change-me-before-use

# Required: upstream gateway base URL
PROXY_URL=https://api.example.com

# Optional: comma-separated extra allowed CORS origins (beyond localhost)
# ALLOWED_ORIGINS=https://your-admin-host.example.com

# Required for docker-compose mysql service
MYSQL_ROOT_PASSWORD=change-me-before-use
MYSQL_DATABASE=apiproxy

MYSQL_DSN=root:change-me-before-use@tcp(127.0.0.1:3306)/apiproxy?parseTime=true
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# Optional: VLM model used for price screenshot OCR (defaults to claude-opus-4-8)
# OCR_MODEL=claude-opus-4-8
# Required for OCR: upstream API key used to call the VLM
# OCR_API_KEY=sk-xxxx

# Optional: upstream "quota exhausted" failover detection. When an upstream
# response's status is in UPSTREAM_EXHAUSTED_STATUS AND its body contains any of
# UPSTREAM_EXHAUSTED_PATTERNS (case-insensitive), the proxy marks that root key
# exhausted for the current month and fails over to the next bound root. All
# non-2xx upstream responses are logged so you can capture the real body and
# tune these without recompiling. Defaults shown below.
# UPSTREAM_EXHAUSTED_STATUS=429,403
# UPSTREAM_EXHAUSTED_PATTERNS=quota,insufficient,exceeded,余额,额度,欠费,balance,arrears

# Optional: timezone whose month boundary resets a root key's exhaustion flag.
# Should match the upstream provider's billing timezone. Defaults to Asia/Shanghai.
# BILLING_TIMEZONE=Asia/Shanghai
